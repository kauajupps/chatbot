function avisoMensal() { 

  // Lista com as URLs dos webhooks de cada espaço individual
  var webhooks = [
     PropertiesService.getScriptProperties().getProperty('cliente1'),
  ];

  webhooks.forEach(function(url) {
    var payload = JSON.stringify({ "text": "Olá! Este é o seu lembrete privado mensal." });
    var options = { "method": "post", "contentType": "application/json", "payload": payload };
    UrlFetchApp.fetch(url, options);
  });
}

